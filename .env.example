# ──────────────────────────────────────────────────────────────
# The Bitter Pundit — contoh environment. Salin: cp .env.example .env
# .env DIABAIKAN git (lihat .gitignore). JANGAN commit nilai asli.
# ──────────────────────────────────────────────────────────────

# Jaringan Sui
SUI_NETWORK=mainnet

# Wallet khusus Walrus Sessions (terisi WAL + SUI).
# ⚠️ KEAMANAN: jangan tempel raw private key di sini untuk produksi.
#    Lebih aman pakai Sui keystore / signer terderivasi. Nilai di bawah
#    hanya placeholder untuk dev lokal.
SESSIONS_WALLET_KEY=suiprivkey1...placeholder...

# Walrus Memory (MemWal) — sesuaikan dgn docs.wal.app saat integrasi
MEMWAL_NETWORK=mainnet
MEMWAL_API_KEY=

# LLM persona engine
LLM_API_KEY=

# Sumber hasil laga (oracle off-chain). Boleh fallback JSON manual bertimestamp.
MATCH_ORACLE_API=

# ── ID on-chain (isi setelah `sui client publish`) ──
NEXT_PUBLIC_PUNDIT_PACKAGE_ID=0x...
NEXT_PUBLIC_PUNDIT_REGISTRY_ID=0x...   # shared ProfileRegistry (anti-Sybil)
PUNDIT_ORACLE_CAP_ID=0x...             # OracleCap operasional (backend)
PUNDIT_ORACLE_ADMIN_CAP_ID=0x...       # OracleAdminCap (recovery: mint OracleCap baru)

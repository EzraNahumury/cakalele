# Frontend env. On Vercel, set these in Project → Settings → Environment Variables,
# then redeploy (NEXT_PUBLIC_* are baked at build time).

# Deployed backend agent URL (Railway). No trailing slash.
NEXT_PUBLIC_AGENT_URL=https://your-backend.up.railway.app

# Optional — defaults are baked into the code (smart-contract/deployments.mainnet.md):
NEXT_PUBLIC_PUNDIT_PACKAGE_ID=0xe12154f96dd7b13d999d04f69fb792c48ac9b0d82c8eaf2c42ac113f538d136f
NEXT_PUBLIC_PUNDIT_REGISTRY_ID=0xc4f4dd4183f14ca23c8a795a39f84cc5177d45f3536e6b9acc586a3d1db6cf73

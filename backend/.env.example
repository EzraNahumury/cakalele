# ──────────────────────────────────────────────────────────────
# pundit-backend env. Salin: cp .env.example .env  (.env DIABAIKAN git)
# JANGAN commit nilai asli.
# ──────────────────────────────────────────────────────────────

# Sessions wallet (bech32 suiprivkey1...). Pemegang WAL+SUI, owner MemWal account.
# Export dari keystore: sui keytool export --key-identity signalvault --json
SUI_PRIVATE_KEY=suiprivkey1...placeholder...

# MemWal Sui mainnet (default sudah di-bake di script; override kalau perlu)
MEMWAL_PACKAGE_ID=0xcee7a6fd8de52ce645c38332bde23d4a30fd9426bc4681409733dd50958a24c6
MEMWAL_REGISTRY_ID=0x0da982cefa26864ae834a8a0504b904233d49e20fcc17c373c8bed99c75a7edd
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
MEMWAL_NAMESPACE=pundit-smoke

# Diisi SETELAH run pertama (reuse — kontrak izinkan 1 account/wallet):
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=

# ── pundit on-chain contract (Sui mainnet, sudah deployed) ──
NEXT_PUBLIC_PUNDIT_PACKAGE_ID=0xe12154f96dd7b13d999d04f69fb792c48ac9b0d82c8eaf2c42ac113f538d136f
NEXT_PUBLIC_PUNDIT_REGISTRY_ID=0xc4f4dd4183f14ca23c8a795a39f84cc5177d45f3536e6b9acc586a3d1db6cf73
PUNDIT_ORACLE_CAP_ID=0x39e9dbc5cfbbb4c12534d2da14423a65aff2c336fcc24cc4941724770928f8f0
PUNDIT_ORACLE_ADMIN_CAP_ID=0xdc0e103eca282e1fb68f6e123f4c822ae5d062f7085d88d6c0737499c805e052

# LLM persona engine — Ollama Cloud (OpenAI-compatible / native /api/chat)
OLLAMA_HOST=https://ollama.com
OLLAMA_KEY=
OLLAMA_MODEL=qwen3.5-cloud
